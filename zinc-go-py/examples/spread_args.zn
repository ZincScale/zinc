// Test spread operator in function call arguments: args...

void logMsg(String level, String msg, any... args) {
    print("[${level}] ${msg} ${args}")
}

void wrapper(String msg, any... args) {
    logMsg("INFO", msg, args...)
}

void doubleWrap(String msg, any... args) {
    wrapper(msg, args...)
}

void main() {
    logMsg("DEBUG", "direct", "key", "value")
    wrapper("wrapped", "a", 1, "b", 2)
    doubleWrap("double", "x", 42)
}
