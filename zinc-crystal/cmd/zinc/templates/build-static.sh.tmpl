#!/usr/bin/env bash
# Build the {{ .Name }} binary inside the Alpine + Crystal container,
# then extract the static binary into ./bin/ so it can run directly
# on the host. Output is fully portable — no brew / glibc dance.
{{ if .SiblingShards }}#
# Runs from the repo root so sibling shards (path: deps) are
# reachable in the docker build context.
{{ end }}
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
PROJECT_DIR="$(cd "$SCRIPT_DIR/.." && pwd)"
{{ if .SiblingShards }}REPO_ROOT="$(cd "$PROJECT_DIR/.." && pwd)"
BUILD_CTX="$REPO_ROOT"
{{ else }}BUILD_CTX="$PROJECT_DIR"
{{ end }}
IMAGE_TAG="{{ .Name }}:build"

echo "→ docker build (context: $BUILD_CTX)"
docker build --target build -t "$IMAGE_TAG" -f "$PROJECT_DIR/Dockerfile" "$BUILD_CTX"

echo "→ extracting static binary..."
mkdir -p "$PROJECT_DIR/bin"
container_id="$(docker create "$IMAGE_TAG")"
trap 'docker rm "$container_id" >/dev/null 2>&1 || true' EXIT
docker cp "$container_id:/out/{{ .Name }}" "$PROJECT_DIR/bin/{{ .Name }}"
chmod +x "$PROJECT_DIR/bin/{{ .Name }}"

echo
echo "→ verify:"
file  "$PROJECT_DIR/bin/{{ .Name }}"
ls -lh "$PROJECT_DIR/bin/{{ .Name }}"
echo
echo "→ run with: ./bin/{{ .Name }}{{ if .ConfigFile }} {{ .ConfigFile }}{{ end }}"
