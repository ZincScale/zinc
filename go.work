// Go workspace tying zinc-go and zinc-crystal so both can import the
// shared language frontend (parser/, lexer/, errs/) that lives under
// zinc-go/. The frontend was promoted out of zinc-go/internal/ to
// make this share possible — see commit history for the move.
//
// Adding a new transpiler target (e.g. zinc-java in Go, zinc-ts):
// add its module path here and import "zinc-go/parser" from its
// codegen package.

go 1.26.1

use (
	./zinc-go
	./zinc-crystal
)
