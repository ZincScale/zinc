#!/usr/bin/env bash
# zinc-csharp — C# build tool for Zinc projects
# Reads zinc.toml, generates .csproj, delegates to dotnet.
# Produces Native AOT binaries by default.
#
# Usage:
#   zinc-csharp build          Native AOT build (default)
#   zinc-csharp build --jit    JIT build only (fast iteration)
#   zinc-csharp run            Build AOT + run
#   zinc-csharp run --jit      JIT run (faster build, slower runtime)
#   zinc-csharp test           Run tests (JIT, separate from production binary)
#   zinc-csharp test --aot     Publish tests as AOT binary, then run
#   zinc-csharp clean          Remove build artifacts
#   zinc-csharp csproj         Regenerate .csproj from zinc.toml

set -euo pipefail

DOTNET_DIR="$HOME/.dotnet"

# --- Ensure .NET SDK is installed ---
#
# We don't pin to a specific .NET major version — whichever SDK the
# developer already has installed gets used. When no SDK is present,
# we fetch the current stable channel, so the tool auto-adopts the
# latest release as major versions ship (.NET 10 today, .NET 11 when
# it lands, etc.). Users who want a specific version can install it
# themselves; we'll pick it up from PATH without complaint.

ensure_dotnet() {
    export PATH="$DOTNET_DIR:$PATH"

    # Any installed dotnet is acceptable — let users pin versions
    # through their own OS package manager if they need to.
    if command -v dotnet &>/dev/null; then
        return
    fi
    if [[ -f "$DOTNET_DIR/dotnet" ]]; then
        return
    fi

    echo "  .NET SDK not found — installing Current channel..."
    curl -sSL https://dot.net/v1/dotnet-install.sh -o /tmp/dotnet-install.sh
    chmod +x /tmp/dotnet-install.sh
    /tmp/dotnet-install.sh --channel Current --install-dir "$DOTNET_DIR" 2>&1 | tail -3
    rm -f /tmp/dotnet-install.sh
    export PATH="$DOTNET_DIR:$PATH"

    local ver
    ver="$("$DOTNET_DIR/dotnet" --version 2>/dev/null || echo "unknown")"
    echo "  .NET SDK $ver installed to $DOTNET_DIR"
}

ensure_dotnet

# --- Locate project root (walk up until zinc.toml found) ---

find_project_root() {
    local dir="$PWD"
    while [[ "$dir" != "/" ]]; do
        [[ -f "$dir/zinc.toml" ]] && echo "$dir" && return
        dir="$(dirname "$dir")"
    done
    echo ""
}

PROJECT_ROOT="$(find_project_root)"
# A missing zinc.toml is fatal for commands that need one (build,
# run, test, clean, csproj, doctor). `init` creates it; `version` and
# `help` don't need it. Defer the hard error to per-command checks
# via require_project() below.
ZINC_TOML=""
if [[ -n "$PROJECT_ROOT" ]]; then
    ZINC_TOML="$PROJECT_ROOT/zinc.toml"
fi

require_project() {
    if [[ -z "$PROJECT_ROOT" ]]; then
        echo "Error: zinc.toml not found (searched from $PWD to /)" >&2
        echo "       run 'zinc-csharp init [name]' to scaffold a project" >&2
        exit 1
    fi
}

# --- TOML parser (minimal, handles zinc.toml structure) ---

toml_get() {
    local file="$1" section="$2" key="$3" default="${4:-}"
    # No project context → no file to read; return the default. Lets
    # pre-project commands (init, version, help) run without triggering
    # a redirection error on an empty ZINC_TOML path.
    if [[ -z "$file" || ! -f "$file" ]]; then
        echo "$default"
        return
    fi
    local in_section=false value=""
    while IFS= read -r line; do
        line="${line%%#*}"
        line="${line#"${line%%[![:space:]]*}"}"
        line="${line%"${line##*[![:space:]]}"}"
        [ -z "$line" ] && continue
        if [[ "$line" =~ ^\[([a-zA-Z0-9_.]+)\]$ ]]; then
            [[ "${BASH_REMATCH[1]}" == "$section" ]] && in_section=true || in_section=false
            continue
        fi
        if $in_section && [[ "$line" =~ ^([a-zA-Z_]+)[[:space:]]*=[[:space:]]*(.+)$ ]]; then
            local k="${BASH_REMATCH[1]}" v="${BASH_REMATCH[2]}"
            v="${v%\"}" ; v="${v#\"}"
            v="${v%\'}" ; v="${v#\'}"
            [[ "$k" == "$key" ]] && value="$v"
        fi
    done < "$file"
    echo "${value:-$default}"
}

toml_bool() {
    local val; val="$(toml_get "$@")"
    [[ "$val" == "true" ]] && echo "true" || echo "false"
}

# --- Read project name and derive paths ---

PROJECT_NAME="$(toml_get "$ZINC_TOML" "project" "name" "App")"
# Source dir: zinc.toml can specify source_dir, defaults to project name
SOURCE_DIR="$(toml_get "$ZINC_TOML" "project" "source_dir" "$PROJECT_NAME")"
PROJECT_DIR="$PROJECT_ROOT/$SOURCE_DIR"
CSPROJ="$PROJECT_DIR/$PROJECT_NAME.csproj"
BUILD_DIR="$PROJECT_ROOT/build"
BINARY="$BUILD_DIR/$PROJECT_NAME"

# --- .csproj generator ---

generate_csproj() {
    local framework lang_version nullable implicit_usings unsafe
    local server_gc aot strip invariant opt stack_traces trim_metadata

    framework="$(toml_get "$ZINC_TOML" "csharp" "framework" "net10.0")"
    lang_version="$(toml_get "$ZINC_TOML" "csharp" "lang_version" "latest")"
    nullable="$(toml_bool "$ZINC_TOML" "csharp" "nullable" "true")"
    implicit_usings="$(toml_bool "$ZINC_TOML" "csharp" "implicit_usings" "true")"
    unsafe="$(toml_bool "$ZINC_TOML" "csharp" "unsafe" "false")"

    server_gc="$(toml_bool "$ZINC_TOML" "csharp.gc" "server" "true")"

    aot="$(toml_bool "$ZINC_TOML" "csharp.aot" "enabled" "false")"
    strip="$(toml_bool "$ZINC_TOML" "csharp.aot" "strip_symbols" "true")"
    invariant="$(toml_bool "$ZINC_TOML" "csharp.aot" "invariant_globalization" "true")"
    opt="$(toml_get "$ZINC_TOML" "csharp.aot" "optimization" "Size")"
    stack_traces="$(toml_bool "$ZINC_TOML" "csharp.aot" "stack_traces" "false")"
    trim_metadata="$(toml_bool "$ZINC_TOML" "csharp.aot" "trim_metadata" "true")"

    local sdk
    sdk="$(toml_get "$ZINC_TOML" "project" "sdk" "Microsoft.NET.Sdk")"

    mkdir -p "$PROJECT_DIR"

    cat > "$CSPROJ" <<CSPROJ_EOF
<Project Sdk="${sdk}">

  <PropertyGroup>
    <OutputType>Exe</OutputType>
    <TargetFramework>${framework}</TargetFramework>
    <LangVersion>${lang_version}</LangVersion>
    <Nullable>$([ "$nullable" = "true" ] && echo "enable" || echo "disable")</Nullable>
    <ImplicitUsings>$([ "$implicit_usings" = "true" ] && echo "enable" || echo "disable")</ImplicitUsings>
    <AllowUnsafeBlocks>${unsafe}</AllowUnsafeBlocks>
    <ServerGarbageCollection>${server_gc}</ServerGarbageCollection>
  </PropertyGroup>

CSPROJ_EOF

    if [[ "$aot" == "true" ]]; then
        cat >> "$CSPROJ" <<AOT_EOF
  <!-- Native AOT -->
  <PropertyGroup>
    <PublishAot>true</PublishAot>
    <StripSymbols>${strip}</StripSymbols>
    <InvariantGlobalization>${invariant}</InvariantGlobalization>
    <IlcOptimizationPreference>${opt}</IlcOptimizationPreference>
    <IlcGenerateStackTraceData>${stack_traces}</IlcGenerateStackTraceData>
    <StackTraceSupport>${stack_traces}</StackTraceSupport>
    <UseSystemResourceKeys>$([ "$trim_metadata" = "true" ] && echo "true" || echo "false")</UseSystemResourceKeys>
    <IlcTrimMetadata>${trim_metadata}</IlcTrimMetadata>
  </PropertyGroup>

AOT_EOF
    fi

    # NuGet packages
    local packages
    packages="$(toml_get "$ZINC_TOML" "csharp.nuget" "packages" "")"
    packages="${packages#[}" ; packages="${packages%]}"
    if [[ -n "$packages" ]]; then
        echo "  <ItemGroup>" >> "$CSPROJ"
        IFS=',' read -ra PKGS <<< "$packages"
        for pkg in "${PKGS[@]}"; do
            pkg="${pkg//\"/}" ; pkg="${pkg// /}"
            local pkgName="${pkg%%:*}"
            local pkgVer="${pkg##*:}"
            echo "    <PackageReference Include=\"${pkgName}\" Version=\"${pkgVer}\" />" >> "$CSPROJ"
        done
        echo "  </ItemGroup>" >> "$CSPROJ"
        echo "" >> "$CSPROJ"
    fi

    # Project references
    local projects
    projects="$(toml_get "$ZINC_TOML" "csharp.references" "projects" "")"
    projects="${projects#[}" ; projects="${projects%]}"
    if [[ -n "$projects" ]]; then
        echo "  <ItemGroup>" >> "$CSPROJ"
        IFS=',' read -ra REFS <<< "$projects"
        for ref in "${REFS[@]}"; do
            ref="${ref//\"/}" ; ref="${ref// /}"
            echo "    <ProjectReference Include=\"${ref}\" />" >> "$CSPROJ"
        done
        echo "  </ItemGroup>" >> "$CSPROJ"
        echo "" >> "$CSPROJ"
    fi

    echo "</Project>" >> "$CSPROJ"
}

# --- Detect RID ---

detect_rid() {
    local arch; arch="$(uname -m)"
    case "$arch" in
        x86_64)  echo "linux-x64" ;;
        aarch64) echo "linux-arm64" ;;
        arm*)    echo "linux-arm" ;;
        *)       echo "linux-x64" ;;
    esac
}

# --- Commands ---

cmd_csproj() {
    require_project
    generate_csproj
    echo "Generated $CSPROJ from zinc.toml"
}

cmd_build() {
    require_project
    generate_csproj

    # --jit flag always wins. Without it, honor [csharp.aot] enabled
    # in zinc.toml: if disabled, default to JIT. This avoids
    # producing a framework-dependent binary that needs system .NET.
    local aot_enabled
    aot_enabled="$(toml_bool "$ZINC_TOML" "csharp.aot" "enabled" "false")"

    # An explicit RID argument (linux-arm64, etc.) forces AOT cross-compile
    # regardless of toml — that's the documented build-for-target behavior.
    local first="${1:-}"
    local is_rid=false
    case "$first" in
        linux-*|win-*|osx-*) is_rid=true ;;
    esac

    if [[ "$first" == "--jit" ]] || { [[ "$is_rid" == "false" ]] && [[ "$aot_enabled" != "true" ]]; }; then
        echo "Building (JIT)..."
        dotnet build "$PROJECT_DIR" -c Release
    else
        local rid="${1:-$(detect_rid)}"
        mkdir -p "$BUILD_DIR"
        echo "Building AOT binary for $rid..."
        dotnet publish "$PROJECT_DIR" -c Release -r "$rid" -o "$BUILD_DIR" 2>&1

        if [[ -f "$BINARY" ]]; then
            local size; size=$(du -h "$BINARY" | cut -f1)
            echo ""
            echo "Binary: $BINARY ($size)"
        fi
    fi
}

cmd_run() {
    require_project
    generate_csproj

    # --jit flag always wins. Without it, honor [csharp.aot] enabled
    # in zinc.toml: if disabled, use dotnet run (JIT) directly.
    local aot_enabled
    aot_enabled="$(toml_bool "$ZINC_TOML" "csharp.aot" "enabled" "false")"

    if [[ "${1:-}" == "--jit" ]]; then
        echo "Running (JIT)..."
        dotnet run --project "$PROJECT_DIR" -c Release -- "${@:2}"
    elif [[ "$aot_enabled" != "true" ]]; then
        echo "Running (JIT — AOT disabled in zinc.toml)..."
        dotnet run --project "$PROJECT_DIR" -c Release -- "$@"
    else
        if [[ ! -f "$BINARY" ]]; then
            cmd_build
        fi
        "$BINARY" "$@"
    fi
}

cmd_test() {
    require_project
    # Tests are a separate project in tests/zinc.toml
    local test_dir="$PROJECT_ROOT/tests"
    local test_toml="$test_dir/zinc.toml"
    if [[ ! -f "$test_toml" ]]; then
        echo "Error: no tests/zinc.toml found" >&2
        exit 1
    fi

    # First, generate the main project csproj (tests reference it)
    generate_csproj

    # Generate the test project csproj
    local t_name t_source_dir t_project_dir t_csproj
    t_name="$(toml_get "$test_toml" "project" "name" "Tests")"
    t_source_dir="$(toml_get "$test_toml" "project" "source_dir" "$t_name")"
    t_project_dir="$test_dir/$t_source_dir"
    t_csproj="$t_project_dir/$t_name.csproj"

    # Save and swap globals for csproj generation
    local save_toml="$ZINC_TOML" save_dir="$PROJECT_DIR" save_csproj="$CSPROJ" save_name="$PROJECT_NAME"
    ZINC_TOML="$test_toml"
    PROJECT_NAME="$t_name"
    PROJECT_DIR="$t_project_dir"
    CSPROJ="$t_csproj"
    generate_csproj
    ZINC_TOML="$save_toml"
    PROJECT_NAME="$save_name"
    PROJECT_DIR="$save_dir"
    CSPROJ="$save_csproj"

    # Run tests. Any trailing positional args are forwarded to the test
    # binary — for Microsoft.Testing.Platform-based tests this means
    # `zinc test --filter "FooTests"` or `zinc test MyClass.MyMethod`
    # works verbatim; the pattern-forwarding convention mirrors
    # zinc-java's `zinc test <pattern>` → `sbt testOnly <pattern>`.
    if [[ "${1:-}" == "--aot" ]]; then
        shift
        local t_build_dir="$test_dir/build"
        local rid; rid="$(detect_rid)"
        mkdir -p "$t_build_dir"
        echo "Publishing tests as AOT binary for $rid..."
        dotnet publish "$t_project_dir" -c Release -r "$rid" -o "$t_build_dir"
        local t_binary="$t_build_dir/$t_name"
        if [[ ! -x "$t_binary" ]]; then
            echo "Error: AOT test binary not found at $t_binary" >&2
            exit 1
        fi
        echo ""
        echo "Running AOT test binary: $t_binary ($(du -h "$t_binary" | cut -f1))"
        "$t_binary" "$@"
        return $?
    fi
    echo "Running tests..."
    dotnet run --project "$t_csproj" -c Release -- "$@"
    return $?
}

cmd_clean() {
    require_project
    rm -rf "$PROJECT_DIR/bin" "$PROJECT_DIR/obj" "$BUILD_DIR"
    # Also clean test project artifacts
    local test_dir="$PROJECT_ROOT/tests"
    if [[ -d "$test_dir" ]]; then
        find "$test_dir" -type d -name bin -exec rm -rf {} + 2>/dev/null
        find "$test_dir" -type d -name obj -exec rm -rf {} + 2>/dev/null
    fi
    echo "Cleaned build artifacts"
}

cmd_doctor() {
    echo "zinc-csharp diagnostics"
    echo ""

    # dotnet
    if command -v dotnet &>/dev/null; then
        echo "  dotnet: $(which dotnet) ($(dotnet --version 2>/dev/null || echo "?"))"
    elif [[ -f "$DOTNET_DIR/dotnet" ]]; then
        echo "  dotnet: $DOTNET_DIR/dotnet ($("$DOTNET_DIR/dotnet" --version 2>/dev/null || echo "?"))"
    else
        echo "  dotnet: NOT FOUND — the next zinc invocation will install it"
    fi

    # zinc.toml
    if [[ -n "$PROJECT_ROOT" ]]; then
        echo "  project: $PROJECT_ROOT"
        echo "  zinc.toml: $ZINC_TOML"
        echo "  name: $PROJECT_NAME"
        echo "  source: $SOURCE_DIR/"
        echo "  csproj: $CSPROJ"
        echo "  binary: $BINARY"
        if [[ -f "$BINARY" ]]; then
            echo "  binary size: $(du -h "$BINARY" | cut -f1)"
        fi

        # tests
        local test_dir="$PROJECT_ROOT/tests"
        if [[ -f "$test_dir/zinc.toml" ]]; then
            echo "  tests: $test_dir/zinc.toml"
        fi
    else
        echo "  project: (not in a zinc-csharp project — run 'zinc-csharp init' to scaffold one)"
    fi
}

ZINC_CSHARP_VERSION="0.1.0"

cmd_version() {
    echo "zinc-csharp $ZINC_CSHARP_VERSION"
    if command -v dotnet &>/dev/null; then
        echo "dotnet $(dotnet --version 2>/dev/null || echo "?") ($(which dotnet))"
    elif [[ -f "$DOTNET_DIR/dotnet" ]]; then
        echo "dotnet $("$DOTNET_DIR/dotnet" --version 2>/dev/null || echo "?") ($DOTNET_DIR/dotnet)"
    else
        echo "dotnet: not installed"
    fi
}

# Scaffold a new zinc-csharp project. Writes zinc.toml + a
# minimal Program.cs in the target directory, plus a tests/ subproject
# with the same shape. Mirrors zinc-java's init: the generated
# zinc.toml is not rewritten on subsequent commands — users edit it
# directly.
cmd_init() {
    local name="${1:-}"
    local target_dir
    if [[ -z "$name" ]]; then
        target_dir="$PWD"
        name="$(basename "$target_dir")"
    else
        target_dir="$PWD/$name"
        if [[ -e "$target_dir" && ! -z "$(ls -A "$target_dir" 2>/dev/null)" ]]; then
            echo "Error: '$target_dir' already exists and is not empty" >&2
            exit 1
        fi
        mkdir -p "$target_dir"
    fi

    if [[ -f "$target_dir/zinc.toml" ]]; then
        echo "Error: $target_dir/zinc.toml already exists" >&2
        exit 1
    fi

    # Normalize the project identifier — C# types can't contain dashes,
    # and the Program.cs namespace uses this name too. Users with a
    # dash-named directory get a CamelCased identifier.
    local ident
    ident="$(echo "$name" | awk -F- '{ for (i=1; i<=NF; i++) printf "%s%s", toupper(substr($i,1,1)), substr($i,2); print "" }')"
    [[ -z "$ident" ]] && ident="App"

    mkdir -p "$target_dir/$ident"
    mkdir -p "$target_dir/tests/Tests"

    cat > "$target_dir/zinc.toml" <<EOF
[project]
name = "$ident"
version = "0.1.0"
source_dir = "$ident"

[csharp]
framework = "net10.0"

[csharp.aot]
enabled = true
strip_symbols = true
optimization = "Size"
EOF

    cat > "$target_dir/$ident/Program.cs" <<EOF
Console.WriteLine("Hello from $ident!");
Console.WriteLine(\$"Runtime: {System.Runtime.InteropServices.RuntimeInformation.FrameworkDescription}");
Console.WriteLine(\$"AOT: {!System.Runtime.CompilerServices.RuntimeFeature.IsDynamicCodeSupported}");
EOF

    cat > "$target_dir/tests/zinc.toml" <<EOF
[project]
name = "Tests"
version = "0.1.0"
source_dir = "Tests"

[csharp]
framework = "net10.0"

[csharp.references]
projects = ["../../$ident/$ident.csproj"]
EOF

    cat > "$target_dir/tests/Tests/Program.cs" <<EOF
// Minimal test runner — replace with your framework of choice
// (Microsoft.Testing.Platform + xUnit, NUnit, etc.). This placeholder
// exits 0 on success, 1 on failure so CI can wire it up as-is.
int failures = 0;
try
{
    // sanity
    if (1 + 1 != 2) { Console.Error.WriteLine("FAIL: arithmetic"); failures++; }
    else Console.WriteLine("PASS: arithmetic");
}
catch (Exception ex)
{
    Console.Error.WriteLine(\$"FAIL: unhandled — {ex.Message}");
    failures++;
}
return failures;
EOF

    cat > "$target_dir/.gitignore" <<'EOF'
bin/
obj/
build/
EOF

    echo "Initialized zinc-csharp project '$ident' in $target_dir"
    echo ""
    echo "Next:"
    echo "  cd $target_dir"
    echo "  zinc-csharp build"
    echo "  zinc-csharp run"
    echo "  zinc-csharp test"
}

cmd_help() {
    cat <<HELP
zinc-csharp — C# build tool for Zinc projects

Commands:
  init [name]      Scaffold a new project (in ./<name> or current dir if omitted)
  build            Native AOT build (default)
  build --jit      JIT-only build (fast iteration)
  build <rid>      Cross-compile AOT for target (e.g. linux-arm64)
  run              Build AOT + run
  run --jit        JIT run (faster build, slower runtime)
  test [pattern]   Run tests (JIT); pattern forwards to the test binary
  test --aot [pat] Publish tests as AOT binary, then run with optional pattern
  csproj           Regenerate .csproj from zinc.toml
  clean            Remove build artifacts
  doctor           Check toolchain and project status
  version          Print zinc-csharp + dotnet versions
  help             Show this help

Config:  zinc.toml → <source_dir>/<name>.csproj (generated)
Output:  build/<name> (AOT binary)

.NET SDK: whichever version is on PATH is used. If none is installed,
the Current channel is fetched to ~/.dotnet on first run — so the tool
auto-adopts new major versions as they ship.
HELP
}

# --- Main ---

CMD="${1:-help}"
shift 2>/dev/null || true

case "$CMD" in
    init)    cmd_init "$@" ;;
    build)   cmd_build "$@" ;;
    run)     cmd_run "$@" ;;
    test)    cmd_test "$@" ;;
    clean)   cmd_clean "$@" ;;
    csproj)  cmd_csproj "$@" ;;
    doctor)  cmd_doctor "$@" ;;
    version|-v|--version) cmd_version ;;
    help|-h|--help) cmd_help ;;
    *)
        echo "Unknown command: $CMD" >&2
        cmd_help >&2
        exit 1
        ;;
esac
