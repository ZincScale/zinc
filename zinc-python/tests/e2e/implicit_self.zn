class Stack {
    def init() {
        self.items = []
    }

    def push(item) {
        self.items.append(item)
    }

    def pop() {
        return self.items.pop()
    }

    def peek() {
        return self.items[-1]
    }

    def size() {
        return len(self.items)
    }

    def toString() {
        return "Stack({self.items})"
    }

    @staticmethod
    def from_list(items) {
        s = Stack()
        for item in items {
            s.push(item)
        }
        return s
    }
}

def main() {
    s = Stack()
    s.push(1)
    s.push(2)
    s.push(3)
    print(s)
    print(s.peek())
    print(s.pop())
    print(s.size())

    s2 = Stack.from_list([10, 20, 30])
    print(s2)
}
