#!/usr/bin/env bash
# caravan-csharp — C# build tool for Caravan projects
# Reads caravan.toml, generates .csproj, delegates to dotnet.
# Produces Native AOT binaries by default.
#
# Usage:
#   caravan-csharp build          Native AOT build (default)
#   caravan-csharp build --jit    JIT build only (fast iteration)
#   caravan-csharp run            Build AOT + run
#   caravan-csharp run --jit      JIT run (faster build, slower runtime)
#   caravan-csharp test           Run tests (JIT, separate from production binary)
#   caravan-csharp test --aot     Publish tests as AOT binary, then run
#   caravan-csharp clean          Remove build artifacts
#   caravan-csharp csproj         Regenerate .csproj from caravan.toml

set -euo pipefail

DOTNET_DIR="$HOME/.dotnet"

# --- Ensure .NET SDK is installed ---

ensure_dotnet() {
    export PATH="$DOTNET_DIR:$PATH"

    # Check if dotnet 10.x is available
    if command -v dotnet &>/dev/null; then
        local ver
        ver="$(dotnet --version 2>/dev/null || echo "")"
        if [[ "$ver" == 10.* ]]; then
            return
        fi
    fi

    if [[ -f "$DOTNET_DIR/dotnet" ]]; then
        local ver
        ver="$("$DOTNET_DIR/dotnet" --version 2>/dev/null || echo "")"
        if [[ "$ver" == 10.* ]]; then
            return
        fi
    fi

    echo "  .NET 10 SDK not found — installing..."
    curl -sSL https://dot.net/v1/dotnet-install.sh -o /tmp/dotnet-install.sh
    chmod +x /tmp/dotnet-install.sh
    /tmp/dotnet-install.sh --channel 10.0 --install-dir "$DOTNET_DIR" 2>&1 | tail -3
    rm -f /tmp/dotnet-install.sh
    export PATH="$DOTNET_DIR:$PATH"

    local ver
    ver="$("$DOTNET_DIR/dotnet" --version 2>/dev/null || echo "unknown")"
    echo "  .NET SDK $ver installed to $DOTNET_DIR"
}

ensure_dotnet

# --- Locate project root (walk up until caravan.toml found) ---

find_project_root() {
    local dir="$PWD"
    while [[ "$dir" != "/" ]]; do
        [[ -f "$dir/caravan.toml" ]] && echo "$dir" && return
        dir="$(dirname "$dir")"
    done
    echo ""
}

PROJECT_ROOT="$(find_project_root)"
if [[ -z "$PROJECT_ROOT" ]]; then
    echo "Error: caravan.toml not found (searched from $PWD to /)" >&2
    exit 1
fi

CARAVAN_TOML="$PROJECT_ROOT/caravan.toml"

# --- TOML parser (minimal, handles caravan.toml structure) ---

toml_get() {
    local file="$1" section="$2" key="$3" default="${4:-}"
    local in_section=false value=""
    while IFS= read -r line; do
        line="${line%%#*}"
        line="${line#"${line%%[![:space:]]*}"}"
        line="${line%"${line##*[![:space:]]}"}"
        [ -z "$line" ] && continue
        if [[ "$line" =~ ^\[([a-zA-Z0-9_.]+)\]$ ]]; then
            [[ "${BASH_REMATCH[1]}" == "$section" ]] && in_section=true || in_section=false
            continue
        fi
        if $in_section && [[ "$line" =~ ^([a-zA-Z_]+)[[:space:]]*=[[:space:]]*(.+)$ ]]; then
            local k="${BASH_REMATCH[1]}" v="${BASH_REMATCH[2]}"
            v="${v%\"}" ; v="${v#\"}"
            v="${v%\'}" ; v="${v#\'}"
            [[ "$k" == "$key" ]] && value="$v"
        fi
    done < "$file"
    echo "${value:-$default}"
}

toml_bool() {
    local val; val="$(toml_get "$@")"
    [[ "$val" == "true" ]] && echo "true" || echo "false"
}

# --- Read project name and derive paths ---

PROJECT_NAME="$(toml_get "$CARAVAN_TOML" "project" "name" "App")"
# Source dir: caravan.toml can specify source_dir, defaults to project name
SOURCE_DIR="$(toml_get "$CARAVAN_TOML" "project" "source_dir" "$PROJECT_NAME")"
PROJECT_DIR="$PROJECT_ROOT/$SOURCE_DIR"
CSPROJ="$PROJECT_DIR/$PROJECT_NAME.csproj"
BUILD_DIR="$PROJECT_ROOT/build"
BINARY="$BUILD_DIR/$PROJECT_NAME"

# --- .csproj generator ---

generate_csproj() {
    local framework lang_version nullable implicit_usings unsafe
    local server_gc aot strip invariant opt stack_traces trim_metadata

    framework="$(toml_get "$CARAVAN_TOML" "csharp" "framework" "net10.0")"
    lang_version="$(toml_get "$CARAVAN_TOML" "csharp" "lang_version" "latest")"
    nullable="$(toml_bool "$CARAVAN_TOML" "csharp" "nullable" "true")"
    implicit_usings="$(toml_bool "$CARAVAN_TOML" "csharp" "implicit_usings" "true")"
    unsafe="$(toml_bool "$CARAVAN_TOML" "csharp" "unsafe" "false")"

    server_gc="$(toml_bool "$CARAVAN_TOML" "csharp.gc" "server" "true")"

    aot="$(toml_bool "$CARAVAN_TOML" "csharp.aot" "enabled" "false")"
    strip="$(toml_bool "$CARAVAN_TOML" "csharp.aot" "strip_symbols" "true")"
    invariant="$(toml_bool "$CARAVAN_TOML" "csharp.aot" "invariant_globalization" "true")"
    opt="$(toml_get "$CARAVAN_TOML" "csharp.aot" "optimization" "Size")"
    stack_traces="$(toml_bool "$CARAVAN_TOML" "csharp.aot" "stack_traces" "false")"
    trim_metadata="$(toml_bool "$CARAVAN_TOML" "csharp.aot" "trim_metadata" "true")"

    local sdk
    sdk="$(toml_get "$CARAVAN_TOML" "project" "sdk" "Microsoft.NET.Sdk")"

    mkdir -p "$PROJECT_DIR"

    cat > "$CSPROJ" <<CSPROJ_EOF
<Project Sdk="${sdk}">

  <PropertyGroup>
    <OutputType>Exe</OutputType>
    <TargetFramework>${framework}</TargetFramework>
    <LangVersion>${lang_version}</LangVersion>
    <Nullable>$([ "$nullable" = "true" ] && echo "enable" || echo "disable")</Nullable>
    <ImplicitUsings>$([ "$implicit_usings" = "true" ] && echo "enable" || echo "disable")</ImplicitUsings>
    <AllowUnsafeBlocks>${unsafe}</AllowUnsafeBlocks>
    <ServerGarbageCollection>${server_gc}</ServerGarbageCollection>
  </PropertyGroup>

CSPROJ_EOF

    if [[ "$aot" == "true" ]]; then
        cat >> "$CSPROJ" <<AOT_EOF
  <!-- Native AOT -->
  <PropertyGroup>
    <PublishAot>true</PublishAot>
    <StripSymbols>${strip}</StripSymbols>
    <InvariantGlobalization>${invariant}</InvariantGlobalization>
    <IlcOptimizationPreference>${opt}</IlcOptimizationPreference>
    <IlcGenerateStackTraceData>${stack_traces}</IlcGenerateStackTraceData>
    <StackTraceSupport>${stack_traces}</StackTraceSupport>
    <UseSystemResourceKeys>$([ "$trim_metadata" = "true" ] && echo "true" || echo "false")</UseSystemResourceKeys>
    <IlcTrimMetadata>${trim_metadata}</IlcTrimMetadata>
  </PropertyGroup>

AOT_EOF
    fi

    # NuGet packages
    local packages
    packages="$(toml_get "$CARAVAN_TOML" "csharp.nuget" "packages" "")"
    packages="${packages#[}" ; packages="${packages%]}"
    if [[ -n "$packages" ]]; then
        echo "  <ItemGroup>" >> "$CSPROJ"
        IFS=',' read -ra PKGS <<< "$packages"
        for pkg in "${PKGS[@]}"; do
            pkg="${pkg//\"/}" ; pkg="${pkg// /}"
            local pkgName="${pkg%%:*}"
            local pkgVer="${pkg##*:}"
            echo "    <PackageReference Include=\"${pkgName}\" Version=\"${pkgVer}\" />" >> "$CSPROJ"
        done
        echo "  </ItemGroup>" >> "$CSPROJ"
        echo "" >> "$CSPROJ"
    fi

    # Project references
    local projects
    projects="$(toml_get "$CARAVAN_TOML" "csharp.references" "projects" "")"
    projects="${projects#[}" ; projects="${projects%]}"
    if [[ -n "$projects" ]]; then
        echo "  <ItemGroup>" >> "$CSPROJ"
        IFS=',' read -ra REFS <<< "$projects"
        for ref in "${REFS[@]}"; do
            ref="${ref//\"/}" ; ref="${ref// /}"
            echo "    <ProjectReference Include=\"${ref}\" />" >> "$CSPROJ"
        done
        echo "  </ItemGroup>" >> "$CSPROJ"
        echo "" >> "$CSPROJ"
    fi

    echo "</Project>" >> "$CSPROJ"
}

# --- Detect RID ---

detect_rid() {
    local arch; arch="$(uname -m)"
    case "$arch" in
        x86_64)  echo "linux-x64" ;;
        aarch64) echo "linux-arm64" ;;
        arm*)    echo "linux-arm" ;;
        *)       echo "linux-x64" ;;
    esac
}

# --- Commands ---

cmd_csproj() {
    generate_csproj
    echo "Generated $CSPROJ from caravan.toml"
}

cmd_build() {
    generate_csproj

    if [[ "${1:-}" == "--jit" ]]; then
        echo "Building (JIT)..."
        dotnet build "$PROJECT_DIR" -c Release
    else
        local rid="${1:-$(detect_rid)}"
        mkdir -p "$BUILD_DIR"
        echo "Building AOT binary for $rid..."
        dotnet publish "$PROJECT_DIR" -c Release -r "$rid" -o "$BUILD_DIR" 2>&1

        if [[ -f "$BINARY" ]]; then
            local size; size=$(du -h "$BINARY" | cut -f1)
            echo ""
            echo "Binary: $BINARY ($size)"
        fi
    fi
}

cmd_run() {
    if [[ "${1:-}" == "--jit" ]]; then
        generate_csproj
        echo "Running (JIT)..."
        dotnet run --project "$PROJECT_DIR" -c Release -- "${@:2}"
    else
        if [[ ! -f "$BINARY" ]]; then
            cmd_build
        fi
        "$BINARY" "$@"
    fi
}

cmd_test() {
    # Tests are a separate project in tests/caravan.toml
    local test_dir="$PROJECT_ROOT/tests"
    local test_toml="$test_dir/caravan.toml"
    if [[ ! -f "$test_toml" ]]; then
        echo "Error: no tests/caravan.toml found" >&2
        exit 1
    fi

    # First, generate the main project csproj (tests reference it)
    generate_csproj

    # Generate the test project csproj
    local t_name t_source_dir t_project_dir t_csproj
    t_name="$(toml_get "$test_toml" "project" "name" "Tests")"
    t_source_dir="$(toml_get "$test_toml" "project" "source_dir" "$t_name")"
    t_project_dir="$test_dir/$t_source_dir"
    t_csproj="$t_project_dir/$t_name.csproj"

    # Save and swap globals for csproj generation
    local save_toml="$CARAVAN_TOML" save_dir="$PROJECT_DIR" save_csproj="$CSPROJ" save_name="$PROJECT_NAME"
    CARAVAN_TOML="$test_toml"
    PROJECT_NAME="$t_name"
    PROJECT_DIR="$t_project_dir"
    CSPROJ="$t_csproj"
    generate_csproj
    CARAVAN_TOML="$save_toml"
    PROJECT_NAME="$save_name"
    PROJECT_DIR="$save_dir"
    CSPROJ="$save_csproj"

    # Run tests
    if [[ "${1:-}" == "--aot" ]]; then
        local t_build_dir="$test_dir/build"
        local rid; rid="$(detect_rid)"
        mkdir -p "$t_build_dir"
        echo "Publishing tests as AOT binary for $rid..."
        dotnet publish "$t_project_dir" -c Release -r "$rid" -o "$t_build_dir"
        local t_binary="$t_build_dir/$t_name"
        if [[ ! -x "$t_binary" ]]; then
            echo "Error: AOT test binary not found at $t_binary" >&2
            exit 1
        fi
        echo ""
        echo "Running AOT test binary: $t_binary ($(du -h "$t_binary" | cut -f1))"
        "$t_binary"
        return $?
    fi
    echo "Running tests..."
    dotnet run --project "$t_csproj" -c Release
    return $?
}

cmd_clean() {
    rm -rf "$PROJECT_DIR/bin" "$PROJECT_DIR/obj" "$BUILD_DIR"
    # Also clean test project artifacts
    local test_dir="$PROJECT_ROOT/tests"
    if [[ -d "$test_dir" ]]; then
        find "$test_dir" -type d -name bin -exec rm -rf {} + 2>/dev/null
        find "$test_dir" -type d -name obj -exec rm -rf {} + 2>/dev/null
    fi
    echo "Cleaned build artifacts"
}

cmd_doctor() {
    echo "caravan-csharp diagnostics"
    echo ""

    # dotnet
    if command -v dotnet &>/dev/null; then
        echo "  dotnet: $(which dotnet) ($(dotnet --version 2>/dev/null || echo "?"))"
    elif [[ -f "$DOTNET_DIR/dotnet" ]]; then
        echo "  dotnet: $DOTNET_DIR/dotnet ($("$DOTNET_DIR/dotnet" --version 2>/dev/null || echo "?"))"
    else
        echo "  dotnet: NOT FOUND — run: caravan-csharp setup"
    fi

    # caravan.toml
    if [[ -n "$PROJECT_ROOT" ]]; then
        echo "  project: $PROJECT_ROOT"
        echo "  caravan.toml: $CARAVAN_TOML"
        echo "  name: $PROJECT_NAME"
        echo "  source: $SOURCE_DIR/"
        echo "  csproj: $CSPROJ"
        echo "  binary: $BINARY"
        if [[ -f "$BINARY" ]]; then
            echo "  binary size: $(du -h "$BINARY" | cut -f1)"
        fi
    fi

    # tests
    local test_dir="$PROJECT_ROOT/tests"
    if [[ -f "$test_dir/caravan.toml" ]]; then
        echo "  tests: $test_dir/caravan.toml"
    fi
}

cmd_help() {
    cat <<HELP
caravan-csharp — C# build tool for Caravan projects

Commands:
  build            Native AOT build (default)
  build --jit      JIT-only build (fast iteration)
  build <rid>      Cross-compile AOT for target (e.g. linux-arm64)
  run              Build AOT + run
  run --jit        JIT run (faster build, slower runtime)
  test             Run tests (JIT, separate from production binary)
  test --aot       Publish tests as AOT binary, then run
  csproj           Regenerate .csproj from caravan.toml
  clean            Remove build artifacts
  doctor           Check toolchain and project status
  help             Show this help

Config:  caravan.toml → $SOURCE_DIR/$PROJECT_NAME.csproj (generated)
Output:  build/$PROJECT_NAME (AOT binary)
HELP
}

# --- Main ---

CMD="${1:-help}"
shift 2>/dev/null || true

case "$CMD" in
    build)   cmd_build "$@" ;;
    run)     cmd_run "$@" ;;
    test)    cmd_test "$@" ;;
    clean)   cmd_clean "$@" ;;
    csproj)  cmd_csproj "$@" ;;
    doctor)  cmd_doctor "$@" ;;
    help|-h|--help) cmd_help ;;
    *)
        echo "Unknown command: $CMD" >&2
        cmd_help >&2
        exit 1
        ;;
esac
