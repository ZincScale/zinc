// errors — base class and common error types for Zinc.
//
// `Err` is the base class. Any class extending Err is an error; the
// compiler widens the signature of any function returning one. Err has
// an `Error() string` method so instances satisfy Go's `error`
// interface — this composes with `errors.Is`, `errors.As`,
// `fmt.Errorf("%w", ...)`, etc.
//
// Usage:
//
//     import stdlib/errors
//
//     Config loadConfig(String path) {
//         if (path == "") {
//             return errors.IllegalArgumentError("path is required")
//         }
//         ...
//     }
//
// Users define their own domain errors by extending Err.

// Err is the base class for all Zinc errors.
pub class Err {
    pub String message

    init(String message) {
        this.message = message
    }

    pub String Error() {
        return message
    }

    pub String toString() {
        return "Err(${message})"
    }
}

// IllegalArgumentError — invalid argument passed to a function.
pub class IllegalArgumentError : Err {
    init(String message) { super(message) }
}

// IllegalStateError — object is in the wrong state for the call.
pub class IllegalStateError : Err {
    init(String message) { super(message) }
}

// IOError — I/O operation failed.
pub class IOError : Err {
    init(String message) { super(message) }
}

// ConfigError — configuration or setup error.
pub class ConfigError : Err {
    init(String message) { super(message) }
}
