// Regression: control-flow keywords (if/while/for/else if/match/lock/
// parallel for) require parens around the condition/subject. The
// bare form is a compile error. Same rule as Java/C#/Swift — one way
// to parse the header, no ambiguity with brace-literal start.

void main() {
    var x = 5
    if x > 0 {
        print("bare if — should fail")
    }
}
