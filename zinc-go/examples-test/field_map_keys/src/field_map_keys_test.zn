// Regression for ZCA-11: Map<K,V>.keys() / .values() on a class field
// must return the typed []K / []V, not []interface{}. Before the fix,
// the rewrite consulted varTypeExprs keyed by a plain name like "foo",
// but for a field access the receiver formatted as "s.foo" — lookup
// missed → fell back to []interface{} → downstream code that indexed
// or iterated the result failed to type-check.

class Registry {
    var items = Map<String, int>{}

    init() {}

    pub fn add(String name, int value) {
        items[name] = value
    }

    // Exercises field.keys() — prior to ZCA-11 fix this would have
    // compiled to `func() []interface{} { ... }()`, making `for k in keys`
    // yield `k` as interface{} and breaking `m[k]` map-index below.
    pub fn total(): int {
        var sum = 0
        var keys = items.keys()
        for k in keys {
            sum = sum + items[k]
        }
        return sum
    }

    // Exercises field.values() — same issue, but for values.
    pub fn maxValue(): int {
        var best = 0
        var vals = items.values()
        for v in vals {
            if v > best {
                best = v
            }
        }
        return best
    }
}

test "Map<K,V>.keys() on a class field is typed []K, not []interface{}" {
    var r = Registry()
    r.add("a", 1)
    r.add("b", 2)
    r.add("c", 3)

    var tot = r.total()
    if tot != 6 {
        t.Errorf("total() = %v, want 6", tot)
    }
}

test "Map<K,V>.values() on a class field is typed []V, not []interface{}" {
    var r = Registry()
    r.add("x", 10)
    r.add("y", 42)
    r.add("z", 7)

    var m = r.maxValue()
    if m != 42 {
        t.Errorf("maxValue() = %v, want 42", m)
    }
}

// ZCA-11b: `var sub = field[key]` pulls out a nested map value. The
// local `sub` should inherit the Map<K2,V2> type so `sub.keys()` / the
// map-index form `sub[k2]` stay typed. Without the type propagation in
// emitVarStmt, `for k in sub.keys()` gave `k` as interface{} and
// `sub[k]` failed to type-check.

class Nested {
    var groups = Map<String, Map<String, int>>{}

    init() {}

    pub fn set(String g, String k, int v) {
        if !groups.containsKey(g) {
            groups[g] = Map<String, int>{}
        }
        groups[g][k] = v
    }

    pub fn sumGroup(String g): int {
        var sub = groups[g]
        var total = 0
        for k in sub.keys() {
            total = total + sub[k]
        }
        return total
    }
}

test "local var = field[key] inherits Map<K,V> type through index expression" {
    var n = Nested()
    n.set("team-a", "alice", 10)
    n.set("team-a", "bob", 20)
    n.set("team-b", "x", 100)

    if n.sumGroup("team-a") != 30 {
        t.Errorf("sumGroup(team-a) = %v, want 30", n.sumGroup("team-a"))
    }
    if n.sumGroup("team-b") != 100 {
        t.Errorf("sumGroup(team-b) = %v, want 100", n.sumGroup("team-b"))
    }
}
