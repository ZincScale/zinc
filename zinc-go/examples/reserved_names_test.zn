// This file is intentionally invalid — it tests that reserved type names
// are rejected by the parser. Run each line individually to verify the error.
// DO NOT include this in the normal test suite — it should FAIL to compile.

fn main() {
    var int = 5           // ERROR: 'int' is reserved
    var long = 10         // ERROR: 'long' is reserved
    var double = 3.14     // ERROR: 'double' is reserved
    var float = 2.0       // ERROR: 'float' is reserved
    var str = "hello"     // ERROR: 'str' is reserved
    var bool = true       // ERROR: 'bool' is reserved
    var byte = 0xFF       // ERROR: 'byte' is reserved
    var char = 65         // ERROR: 'char' is reserved
}
