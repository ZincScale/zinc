// Bug 2: assigning a class-returning function's `catch { }` result to a `T?`
// local double-wraps with _zincPtr.
class Box {
    pub String name
    init(String n) { this.name = n }
}

(Box, error) makeBox(String n) {
    return Box(n)
}

void main() {
    Box? x
    var v = makeBox("hello") catch { return }
    x = v   // BUG: emits `x = _zincPtr(v)` which is **Box, not *Box.
    if (x != null) {
        print((x as Box).name)
    }
}
