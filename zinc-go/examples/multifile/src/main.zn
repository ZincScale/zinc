// Main — uses types and functions from model.zn and service.zn

fn main() {
    var alice = User("Alice", 30)
    var bob = User("Bob", 15)
    var widget = Product("Widget", 9.99)

    print(greetUser(alice))
    print(greetUser(bob))
    print(describeUser(alice))
    print(describeUser(bob))
    print("Alice adult: {isAdult(alice)}")
    print("Bob adult: {isAdult(bob)}")
    print(formatPrice(widget))
    print("Multi-file OK")
}
