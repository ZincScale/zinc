// constants.zn — Constants and immutable values

const PI = 3.14159
const MAX_RETRIES = 3
const APP_NAME = "zinc-app"

fn circle_area(radius: float): float {
    return PI * radius ** 2
}

fn circle_circumference(radius: float): float {
    return 2 * PI * radius
}

print("App: {APP_NAME}")
print("Area of r=5: {circle_area(5.0)}")
print("Circumference of r=5: {circle_circumference(5.0)}")
print("Max retries: {MAX_RETRIES}")
