// type_checking.zn — Type annotations, is checks, none

// Type annotations
var str name = "Alice"
var int age = 30
var List<int> scores = [95, 87, 92]
var dict config = {"debug": true}

// Type checking with is — transpiler generates isinstance()
fn describe(any x) {
    if x is str {
        print("string: {x}")
    } else if x is int {
        print("integer: {x}")
    } else if x is list {
        print("list with {len(x)} items")
    } else {
        print("something else: {x}")
    }
}

describe("hello")
describe(42)
describe([1, 2, 3])
describe(3.14)

// None checks
var value = none
if value is none {
    print("value is none")
}

value = "found"
if value is not none {
    print("value: {value}")
}

// not in
var allowed = ["admin", "editor", "viewer"]
var role = "guest"
if role not in allowed {
    print("{role} is not allowed")
}
