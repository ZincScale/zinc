package "myapp/models"

class Animal {
    var name: String
    var sound: String

    construct new(name: String, sound: String) {
        this.name = name
        this.sound = sound
    }

    pub fn speak(): String {
        return "{this.name} says {this.sound}!"
    }

    pub fn getName(): String {
        return this.name
    }
}
