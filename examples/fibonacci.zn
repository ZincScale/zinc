// Fibonacci — demonstrates recursion and basic arithmetic

fib(n Int) Int {
    if n <= 1 {
        return n
    }
    return fib(n - 1) + fib(n - 2)
}

fibIterative(n Int) Int {
    if n <= 1 {
        return n
    }
    a Int = 0
    b Int = 1
    i Int = 2
    while i <= n {
        tmp Int = a + b
        a = b
        b = tmp
        i += 1
    }
    return b
}

main() {
    print("Fibonacci (recursive):")
    i Int = 0
    while i <= 10 {
        print(fib(i))
        i += 1
    }

    print("Fibonacci (iterative):")
    j Int = 0
    while j <= 10 {
        print(fibIterative(j))
        j += 1
    }
}
