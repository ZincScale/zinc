fn divide(a: Int, b: Int): Int {
    if (b == 0) {
        throw Error("division by zero")
    }
    return a / b
}

fn main() {
    try {
        var result = divide(10, 2)
        print(result)
    } catch(err) {
        print("caught error")
    }

    try {
        var result = divide(5, 0)
        print(result)
    } catch(err) {
        print("caught division by zero")
    }
}
