// Counter — lives in actors package, extends Actor

class Counter : Actor {
    var int count = 0

    init(int start) {
        count = start
    }

    pub fn increment() {
        count += 1
    }

    pub fn add(int n) {
        count += n
    }

    pub fn getCount(): int {
        return count
    }

    pub fn reset() {
        count = 0
    }
}
