fn divide(a: Int, b: Int): Int {
    if (b == 0) {
        return Error("division by zero")
    }
    return a / b
}

fn main() {
    // Auto-propagation: panics in main if error occurs
    var result = divide(10, 2)
    print(result)

    // Or handler: add context, log, and halt
    var result2 = divide(5, 0) or {
        print("caught: {err}")
        exit(0)
    }
    print(result2)
}
